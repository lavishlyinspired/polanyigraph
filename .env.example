# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
# Profile selects desktop (local) vs cloud connection details.
PROFILE=desktop

# --- LLM (OpenAI-compatible; NVIDIA-hosted GLM by default) ---
# z-ai/glm-5.2 is listed in NVIDIA's catalog but hung indefinitely on
# /chat/completions when tested (confirmed via direct curl); this model was
# confirmed working (~0.3s response) on the same key/endpoint.
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# --- Neo4j Desktop (LPG: instances + reasoning + viz) ---
NEO4J_URI_DESKTOP=bolt://localhost:7687
NEO4J_DB_USER_DESKTOP=neo4j
NEO4J_DB_PASSWORD_DESKTOP=
NEO4J_DB_DESKTOP=neo4j

# --- Ontotext GraphDB Desktop (ontology: RDF/OWL/SPARQL) ---
# Swap repositoryId to swap the ontology domain (fibo, cco, schema.org, ...).
ONTOTEXT_DB_REPO_URL_DESKTOP=http://localhost:7200/?repositoryId=fibo

# --- Reasoning parameters (tunable; no magic numbers in code) ---
REASON_DECAY=0.45
REASON_EPSILON=0.001
REASON_MAX_ITERATIONS=10

# --- Cloud fallbacks (optional) ---
# NEO4J_CONNECTION_URI_CLOUD=
# NEO4J_USERNAME_CLOUD=
# NEO4J_PASSWORD_CLOUD=
# ONTOTEXT_DB_URL_CLOUD=
# ONTOTEXT_DB_USERNAME_CLOUD=
# ONTOTEXT_DB_PASSWORD_CLOUD=
