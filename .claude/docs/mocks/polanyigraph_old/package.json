    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "latest",
    "express": "^4.19.2",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
